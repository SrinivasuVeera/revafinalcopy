<apex:page controller="RVEEligibleStudentDownloadController" renderAs="pdf" contentType="application/pdf" showHeader="false" applyHtmlTag="false" applyBodyTag="false" standardStylesheets="false">
    <head>
        <style type="text/css">
            body {
            font-family: Arial, sans-serif;
            font-size: 12px;
            margin: 20px;
            position: relative;
            }
            .logo-container {
            text-align: right;
            margin-bottom: 10px;
            }
            .header {
            background-color: #4d4f52;
            color: white;
            text-align: center;
            padding: 10px;
            font-size: 18px;
            font-weight: bold;
            }
            table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
            }
            th, td {
            border: 1px solid #000;
            padding: 8px;
            text-align: center;
            }
            .info-table td {
            font-weight: bold;
            background-color: #f0f0f0;
            width: 50%;
            }
            .info-table td + td {
            font-weight: normal;
            background-color: white;
            }
            .student-table th {
            background-color: #d4d4d9;
            }
            .student-table td {
            text-align: center;
            }
            .watermark {
            position: absolute;
            top: 50%;
            left: 25%;
            z-index: -1;
            opacity: 0.15;
            }
        </style>
    </head>
    
    <body>
        <div class="logo-container">
            <img src="{!$Resource.REVA_LOGO}" width="150" height="70"/>
        </div>
        <div class="header">List Of Students</div>
        
        <!-- Info Table -->
        <table class="info-table">
            <tr>
                <td>School Name</td>
                <td>{!schoolName}</td>
            </tr>
            <tr>
                <td>Program Batch Name</td>
                <td>{!batchName}</td>
            </tr>
            <tr>
                <td>Semester Name</td>
                <td>{!semesterName}</td>
            </tr>
            <tr>
                <td>Eligible For Exam</td>
                <td>{!eligibility}</td>
            </tr>
            <tr>
                <td>Exam Type</td>
                <td>{!examType}</td>
            </tr>
        </table>
        
        <!-- Watermark -->
        <div class="watermark">
            <apex:image url="{!URLFOR($Resource.Reva_Watermark)}" height="400px" />
        </div>
        
        <!-- Student Table -->
        <table class="student-table">
            <thead>
                <tr>
                    <th>S. No</th>
                    <th>Student Name</th>
                    <th>SRN Number</th>
                    <th>Mobile</th>
                    <!-- Fixed Header Structure -->
                    <apex:outputText rendered="{!eligibility == 'Approved by School Director'}">
                        <th>Remarks</th>
                    </apex:outputText>
                    <apex:outputText rendered="{!eligibility == 'Ineligible'}"><th>Total Average Attendance</th></apex:outputText>
                    <apex:outputText rendered="{!eligibility == 'Ineligible'}"><th>Total Pending Amount</th></apex:outputText>
                </tr>
            </thead>
            <tbody>
                <apex:variable var="index" value="{!1}" />
                <apex:repeat value="{!students}" var="stu">
                    <tr>
                        <td>{!index}</td>
                        <td>{!stu.Name}</td>
                        <td>{!stu.SRN_Number__c}</td>
                        <td>{!stu.MobilePhone}</td>
                        <!-- Fixed Column Structure -->
                        
                        <apex:outputText rendered="{!eligibility == 'Approved by School Director'}"><td>{!stu.Description}</td></apex:outputText>
                        
                        
                        <apex:outputText rendered="{!eligibility == 'Ineligible'}"><td>{!stu.Total_average_current_sem_attendance__c}</td></apex:outputText>
                        <!-- <apex:outputText rendered="{!eligibility != 'Ineligible'}">&nbsp;</apex:outputText> -->
                        <apex:outputText rendered="{!eligibility == 'Ineligible'}">
                            <td>
                                <apex:variable var="totalPending" value="{!0}" />
                                <apex:repeat value="{!stu.Student_Fees__r}" var="stufee">
                                    <apex:variable var="totalPending" value="{!totalPending + stufee.Amount_Pending__c}" />
                                </apex:repeat>
                                {!totalPending}
                            </td>
                        </apex:outputText>
                        <!-- <apex:outputText rendered="{!eligibility != 'Ineligible'}">&nbsp;</apex:outputText> -->
                        
                    </tr>
                    <apex:variable var="index" value="{!index + 1}" />
                </apex:repeat>
            </tbody>
        </table>
    </body>
</apex:page>