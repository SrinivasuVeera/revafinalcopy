<apex:page controller="PAOLetterPDFController"
           renderAs="pdf"
           showHeader="false"
           applyHtmlTag="false"
           applyBodyTag="false">
    
    <html>
        <head>
            
            <style>
                
                body{
                font-family: Arial;
                font-size:12px;
                }
                
                .title{
                color: #E97132;;
                text-align:center;
                font-size:20px;
                font-weight:bold;
                }
                
                .section{
                margin-top:20px;
                }
                
                table{
                width:100%;
                border-collapse:collapse;
                }
                
                th, td{
                border:1px solid black;
                padding:6px;
                text-align:center;
                }
                
                .left{
                text-align:left;
                }
                h4{
            color: #E97132;
        }
                h3{
            color: #E97132;
        }
            </style>
            
        </head>
        
        <body>
            <table width="100%" style="border:0; margin-bottom:20px;">
            <tr style="border:0">
            
            <td style="border:0; text-align:left;">
            <img src="{!URLFOR($Resource.Reva_logo1)}" width="160"/>
            </td>
            
            <td style="border:0; text-align:right;">
            <img src="{!URLFOR($Resource.Grade_logo)}" width="140"/>
            </td>
            
            </tr>
            </table>
            
            <div class="title">
                Provisional Admission Offer
            </div>
            
            <br/>
            
            <p>
                <b>Date :</b> {!istFormatted}<br/>
                <b>Student Name :</b> {!con.Name} <br/>
                <b>Application Number :</b> {!con.Application_Number__c} <br/>
                <b>Email :</b> {!con.Email}
            </p>
            
            <br/>
            
            <h3 style="color:#E97132;">
                Greetings from REVA University, Bengaluru!
            </h3>
            
            <p>
                Congratulations! We are pleased to inform you that you have been provisionally selected for admission admission to {!con.Primary_Academic_Program_Name__c} for the Academic Year [2026–27].
            </p>
            
            <div class="section">
                
                <h3 style="color:#E97132;">Programme Information</h3>
                
                <p>
                    Your program duration will be of {!con.Primary_Academic_Program__r.No_of_Years__c} years and your fee structure will be as follows:
                </p>
                
            </div>
            
            <div class="section">
                
                <h3>Fee Structure</h3>
                
                <table border="1" width="100%" cellpadding="6" cellspacing="0">
                    
                    <tr>
                        <th style="color:#E97132;">Particulars</th>
                        
                        <apex:repeat value="{!yearList}" var="yr">
                            <th style="color:#E97132;">{!yr}</th>
                        </apex:repeat>
                        
                        <th style="color:#E97132;">Total</th>
                    </tr>
                    
                    
                    <tr>
                        <td style="color:#E97132;">Annual Fee</td>
                        
                        <apex:repeat value="{!yearList}" var="yr">
                            <td>{!annualFeeMap[yr]}</td>
                        </apex:repeat>
                        
                        <td>{!totalAnnual}</td>
                        
                    </tr>
                    
                    
                    <tr>
                        <td style="color:#E97132;">Scholarship</td>
                        
                        <apex:repeat value="{!yearList}" var="yr">
                            <td>{!scholarshipMap[yr]}</td>
                        </apex:repeat>
                        
                        <td>{!totalScholarship}</td>
                        
                    </tr>
                    
                    
                    <tr style="font-weight:bold;background:#f3f3f3;">
						<td style="color:#E97132;">Net Annual Fee</td>
                        
                        <apex:repeat value="{!yearList}" var="yr">
                            <td>{!netFeeMap[yr]}</td>
                        </apex:repeat>
                        
                        <td>{!totalNet}</td>
                        
                    </tr>
                    
                </table>
                
            </div>
            
            
            <div class="section">
                
                <h3>How to make a payment</h3>
                
                <p>
                    You can pay online through the REVA University payment gateway. Link to the gateway is provided below:
                </p>
                <p>
                    Link here:<a href="{!paymentUrl}" target="_blank">Click here to make payment</a>
                </p>
            </div>
            
            
            <div class="section">
                
                <h3>Eligibility Criteria</h3>
                <p>
                    To confirm your admission to REVA University, please ensure that:
                </p>
                
                <ul>
                    
                    <li>You meet the eligibility requirements mentioned on the programme page on <a href="https://www.reva.edu.in/"></a>.</li>
                    
                    <li>All required academic documents are submitted and verified through the Office of the Registrar via the proper channel.</li>
                    
                </ul>
                <p>
                    Please note that admission is subject to the fulfilment of the above criteria and accurate submission of information.
                </p>
            </div>
            
            
            <div class="section">
                
                <h3>Scholarships</h3>
                
                <p>
                    REVA Scholarships are awarded to students admitted to Undergraduate (UG) and Postgraduate (PG) programmes under the University Quota. Students admitted through KCET or any other quota shall not be eligible, unless expressly included under the specific scholarship category. The scholarships are given in various categories like REVA RISE, Merit, Sports, NCC, Defence/Paramilitary/Police Scholarship, Scholarship for Specially Abled, Staff Children  Sibling Scholarship, Referral Scholarship.
                    
                    For more details, refer the link:<a href="https://www.reva.edu.in/scholarship" target="_blank">REVA Scholarships</a> page.
                </p>
                  
                      <ul style="margin-bottom:40px;">                
                <li><b> NOTE:</b> Continuation of any scholarship is contingent primarily upon maintaining a minimum of 80% attendance and a GPA/SGPA of 8 or above in all subjects, in a single attempt. No other fee concessions shall be carried forward.
                       
                </li>
                </ul> 
            
                
            </div>
            <div class="section">
                
                <h3>RISE</h3>
                
                <p>
                    REVA RISE (REVA Initiative for Scholastic Excellence) is the flagship Scholarship Aptitude Test conducted by REVA University. It is designed to identify, recognise, and reward meritorious and high-potential students who aspire to pursue Undergraduate or Postgraduate programmes at the University. REVA RISE has been introduced to promote scholastic excellence and make quality higher education more accessible. The initiative aims to support deserving students — including those from rural and under-represented backgrounds — by offering merit-based tuition fee waivers.
                    
                    For more details, visit:<a href="https://www.reva.edu.in/reva-rise" target="_blank">REVA RISE</a> page.
                </p>
                
            </div>
            
            
            <div class="section">
                
                <h3>Housing / Hostel Accommodation</h3>
                <p>
                    REVA University offers optional on-campus residential facilities to support students’ academic and personal growth. Accommodation is subject to availability.
                </p>
                <h4>
                    Key Facilities:
                </h4>
                
                <ul>
                    
                    <li>Separate hostels for boys and girls</li>
                    <li>24×7 security with controlled access and CCTV</li>
                    <li>Wi-Fi-enabled rooms and library access</li>
                    <li>Hygienic mess and dining services</li>
                    <li>Laundry, housekeeping, and recreation areas</li>
                    <li>On-campus medical support</li>
                    
                </ul>
                <p>
                    For more details, please visit our <a href="https://www.reva.edu.in/student-housing">accommodation</a> page here.
                </p>
            </div>
            
            
            <div class="section">
                
                <h3>Campus Facilities</h3>
                <p>
                    REVA University offers a modern and well-equipped campus designed to provide a safe, comfortable, and enriching learning environment.
                </p>
                <h4>
                    Key Features:
                </h4>
                <ul>
                    
                    <li>Smart classrooms and advanced laboratories</li>
                    <li>Central library with extensive digital resources</li>
                    <li>Dedicated research centres</li>
                    <li>High-speed Wi-Fi connectivity across campus</li>
                    <li>On-campus hostels</li>
                    <li>Sports and fitness facilities</li>
                    <li>Food courts and dining options</li>
                    <li>Medical and transport services</li>
                    <li>24×7 security and surveillance</li>
                    
                </ul>
                <p>
                    For more details, please visit our <a href="https://www.reva.edu.in/campus-facilities">campus facilities</a> page.
                </p>
            </div>
            
            <div class="section">
                
                <h3>Student mentoring</h3>
                
                <p>
                    REVA University follows a structured student mentoring system where each student is guided by a dedicated faculty mentor. The mentoring programme supports academic progress, personal development, career guidance, and overall well-being, ensuring continuous support throughout the student’s academic journey.
                </p>
                <p>
                    For more information, you can explore our student mentoring page here <a href="https://www.reva.edu.in/360-degree-student-care">Student Mentorship</a>.
                </p>
            </div>
            
            <div class="section">
                
                <h3>Career Development Centre </h3>
                
                <p>
                    REVA University has a dedicated Career Development Centre (CDC) that supports students in achieving strong career outcomes. The Centre provides comprehensive career guidance, employability training, internship opportunities, and placement support. Through industry partnerships, skill development programs, resume building, mock interviews, and career counselling, the PCDC prepares students to meet global industry standards and enhances their professional readiness.
                </p>
                <p>
                    For more information, please visit <a href="https://www.reva.edu.in/placement">placement page</a>.
                </p>
            </div>
            <div class="section">
                
                <h3>Why REVA University? </h3>
                
                <p>
                    REVA University is dynamic and inspiring, offering a perfect blend of academic excellence and campus vibrancy. With modern facilities, active student clubs, sports and cultural festivals, and a supportive learning environment, students enjoy a truly enriching and memorable university experience
                </p>
                <p>
                    You can explore the vibrant life of a REVaite <a href="https://www.reva.edu.in/life-at-reva">LifeatREVA</a> here
                </p>
            </div>
            
            <div class="section">
                
                <h3>Documents to be Submitted at Time of Reporting</h3>
                <p>
                    Kindly ensure to submit the following documents to the registrar's office.
                </p>
                <ul>
                    
                    <li>Original academic certificates and mark sheets</li>
                    <li>Original Transfer/Migration Certificate (as applicable) </li>
                    <li>Passport size photographs</li>
                    <li>Identity proof (Aadhaar/Passport)</li>
                    <li>Any entrance test score cards (e.g., JEE / NATA / NEET / MAT / CAT)</li>
                    <li>Medical fitness certificate (if required)</li>
                    <li>Anti-ragging and anti-drug filing (as per UGC provisions)</li>
                    
                </ul>
                <p>
                    For more specifications, please refer to the link here – <a href="https://www.reva.edu.in/document-checklist">Document checklist</a> 
                </p>
            </div>
            
            
            <div class="section">
                
                <h3>TERMS AND CONDITIONS FOR ADMISSION</h3>
                <h4>
                    1. Confirmation of Admission:
                </h4>
                <p>
                    Your admission will be confirmed upon successful completion of all eligibility requirements and formalities, including payment of the prescribed fees and completion of enrolment procedures within the specified timelines.
                </p>
                <h4>
                    2. Cancellation of Admission:
                </h4>
                <p>
                    REVA University reserves the right to cancel the admission of a candidate under any of the following circumstances:
                </p>
                <ul>
                    <il>Please note that admissions are offered on a first-come, first-served basis and are subject to seat availability.</il>
                    <il>Non-reporting or failure to join the allotted programme within the specified time. ( even if the fees have been paid)</il>
                    <il>Inability to provide valid proof of prescribed eligibility and qualifications.</il>
                    <il>Submission of forged, fabricated, misleading, or invalid documents at any stage.</il>
                    <il>Non-submission of original documents or required eligibility certificates within the notified timeline.</il>
                    <il>Non-submission of equivalence/recognition certificates, where applicable (for qualifications obtained outside India).</il>
                </ul>
               <p>
                   We kindly request that candidates ensure all requirements are fulfilled to avoid any inconvenience.
                </p>
                <h4>
                    3. Refund Policy
                </h4>
                <p>
                    If a candidate does not register or decides to withdraw from the programme, the applicable fee refund will be processed as per the guidelines issued by the University Grants Commission (UGC).
                </p>
                <h4>
                    4. Rules and Regulations – Campus Ethics &amp; Code of Conduct
                </h4>
                <p>
                    Students admitted to REVA University are required to comply with the University’s Rules and Regulations, Campus Ethics, and Code of Conduct. Any form of misconduct, ragging, harassment, substance abuse, academic dishonesty, or damage to university property is strictly prohibited. Non-compliance shall attract disciplinary action in accordance with university policies and applicable laws.
                </p>
                <p>
                    You can get more information about our policy here for <a href="https://www.reva.edu.in/campus-ethics">campus ethics</a>.
                </p>
                <h4>
                    5. Right of Alteration / Modification:
                </h4>
                <ul>
                    <il>REVA University reserves the right to alter or modify the structure, curriculum, or delivery of any academic programme in pursuit of academic excellence.</il>
                    <il>REVA University reserves the right to amend, modify, alter, and/or include any other terms and conditions that may be considered appropriate in the interest of the University.</il>
                </ul>
                <h4>
                    6. Acceptance of Offer
                </h4>
                <p>
                    By accepting this offer and completing the admission formalities, the candidate agrees to abide by all the <b>rules, regulations, and policies of REVA University</b> as in force from time to time.
                </p>
                <!--<p>
                    If you are interested, please accept the offer by selecting the “Approve” button and completing the initial payment. If you have any queries or concerns, please feel free to reach out to us.
                </p> -->
                <p>
                    We look forward to welcoming you to <b>REVA University</b> and wish you a successful academic journey.
                </p>
            </div>
            
            
            <br/><br/>
            
            <p>
                With Best Wishes,<br/>
                {!con.Owner.Name}<br/>
    			{!con.Owner.Email}<br/>
   				{!con.Owner.Phone}<br/>
                Admissions Office <br/>
                REVA University, Bengaluru
            </p>
            
        </body>
        
    </html>
    
</apex:page>