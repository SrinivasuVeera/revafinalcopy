<!--apex:page standardController="Transport_Registeration__c" extensions="RTR_TransportRegInfo" renderAs="pdf"-->
<apex:page standardController="Transport_Registeration__c" extensions="RTR_TransportRegInfo" renderAs="pdf" >
    <apex:stylesheet value="{!$Resource.BusPass}"/>
    <html>
        <head>
            <link href='https://fonts.googleapis.com/css?family=Roboto' rel='stylesheet'/>
            <style>
                body {
                font-family: Roboto, sans-serif;
                }
                  @page {
                    size: A5; 
                    margin: 20mm;
                }
                
            </style>
        </head>
        <apex:outputPanel rendered="{!NOT((transRegList.Registration_Status__c == 'Payment Pending')|| transRegList.Registration_Status__c == 'Cancelled')}">
            <body style = " font-family: Roboto, sans-serif;">
                
                <table style="width:90%; border:10px ">
                    <td style="width: 45%; border: 10px text-align: center; background-color: #F18D00; ">
                    <!--background-color: #0096a1--> 
                        
                        <!-- <div class="horizontal-block"> -->
                        <p style="text-align: center; color: white; margin-left:5px ;"><b>RULES</b></p>
                        <p style="text-align: left; color: white;">
                            <li style="text-align: left; margin-bottom: px; color: white; font-size:11px; ">This Bus Pass is not transferrable</li> </p>
                        <p style="text-align: left; color: white;">
                            <li style="text-align: left; margin-bottom: 5px; color: white; font-size: 11px; ">If this bus pass is lost or damaged,a new card 
                                will be issued against a payment of Rs 500/-
                            </li >
                        </p>
                        <p style="text-align: left; color: white;">
                            <li style="text-align: left; color: white; font-size: 11px; ">If anyone uses a bus pass beyond the valid date 
                                he/she has to pay a fine of Rs 1000/-</li>
                        </p>
                        <br/>
                        
                        <table style="color: #F18D00; background-color: white; margin-bottom:7px; width:100% ; font-size: 10px; border: 2px solid white;">
                            <tr>
                                <th> Date </th>
                                <th>Amount</th>
                                
                            </tr>
                            <apex:repeat value="{!paymentDetails}" var="paymentDetail">
                                <tr  style="background-color:white">
                                    <td><span style="color: black;">{!paymentDetail.paymentDate}</span></td>
                                    <td><span style="color: black">{!paymentDetail.amountPaid}</span></td>                                           
                                </tr>
                            </apex:repeat>
                            <tr style="background-color:white"><td></td><td></td></tr>

                            
                        </table>
                        <br/><br/><br/>
                        
                        <p style="text-align: center;  color: white; margin-left:5px ; font-size: 10px; ">
                            If Found Please Return To<br/>
                            <span style="font-size: 18px;">REVA University</span><br/>
                            Rukmini Knowledge Park, Kattigenahalli<br/>
                            Yelahanka,Bengaluru- 560064,India<br/>
                            PH:+918046966966  Ext.222</p>
                        <!--</div>-->  
                    </td>
                    <td style="width: 45%;">
                        <!-- Second Horizontal Block -->
                        <!--<div class="horizontal-block"> 
<div class="inline-route">-->
                        
                        <apex:image url="{!$Resource.RTR_Logo}" width="140" height="40" style="float: left; margin-right: 5px; margin-left:5px;margin-top:10px"/>
                        <apex:outputPanel rendered="{!transRegList.Bus_Pass_No__c== null}">
                            <p style="display: inline-block; margin-bottom: 15px; margin-left: 30px ;margin-top:10px; margin-right: 5px; font-size: 15px;">
                                <span style="font-weight: bold;font-size: 12px; margin-left: 45px ;margin-top:10px; color: #646666;">Bus Pass No.</span><br />
                                <span style="font-weight: bold; font-size: 20px; margin-left: 50px ; color: #646666;">{!transRegList.Name}</span>
                            </p>
                        </apex:outputPanel>      
                        <apex:outputPanel rendered="{!transRegList.Bus_Pass_No__c!=null}">
                            <p style="display: inline-block; margin-bottom: 30px; margin-left: 20px ;margin-top:25px; margin-right: 5px ; font-size: 15px;">
                                <span style="font-weight: bold;font-size: 12px; margin-left:88px ;margin-top:10px; color: #646666;">Bus Pass No.</span><br />
                                <span style="font-weight: bold; font-size: 20px; margin-left: 90px ;color: #646666;"> {!transRegList.Bus_Pass_No__c}</span>
                            </p>
                            <!--  <p style="display: inline-block; vertical-align: top; margin-bottom: 70px; margin-left: 10px;font-family: Calibri, sans-serif; font-size: 12px; ">Bus Pass No:</p>   -->
                        </apex:outputPanel>
                        
                        <!-- </div> --> 
                        <apex:image url="{!passportPhotoURL}" width="120" height="120" style="display: block; margin: 0 auto; border: 2px solid #F18D00; border-radius: 50% !important;"/>
                        
                        <p style="text-align: center; color: white; margin-bottom: 4px;font-size: 18px; background-color: #F18D00; padding: 5px; ">
                            <b>Name : {!transRegList.Contact__r.FirstName} {!transRegList.Contact__r.LastName}</b>
                        </p>
                        
                        
                        <!-- <p style="text-align: right; margin-left:5px"><b> Affix <br/>Stamp Size <br/> Photograph</b></p> -->             
                        <!-- <div class="inline-route"> -->
                        <p style="text-align: left; margin-left:30px;margin-right:10px; font-size: 10px; ">
                            <apex:outputPanel rendered="{!transRegList.Registration_Type__c=='Student' || transRegList.Registration_Type__c=='Applicant'}">
                                
                                <b><span style="color:  #F18D00;">SRN / AppNo :</span> {!StuSRNNumber}</b><br/>
                                
                                <b> <span style="color:  #F18D00; ">Program Batch : </span>{!transRegList.Contact__r.Program_Batch__r.Name}</b><br/>
                            </apex:outputPanel>
                        </p>
                        <p style="text-align: left; margin-left:30px;margin-right:10px; font-size: 12px; ">
                            <b><span style="color: #F18D00;"> Pickup Point : </span>{!transRegList.Route_Pick_Up_Point__r.Name}</b><br/><br/>
                            
                            <b><span style="color: #F18D00;">Route : </span>{!transRegList.Route_Master__r.Name}</b>
                            <apex:outputPanel rendered="{!transRegList.Registration_Type__c=='Student' || transRegList.Registration_Type__c=='Applicant' }">
                                <b><span style="color: #F18D00;text-align: right; margin-left:55px;margin-bottom:5px; margin-right:10px">Valid Upto : </span><apex:outputText value="{!formattedStartDate}"/></b>                 
                            </apex:outputPanel>
                        </p>
                        <br/>
                        
                        <div >
                            <div style="float: left; clear: both; margin-right:5px;color: #5c5e5e; font-size: 9px;">
                                <hr style="border: none; border-top: 1px dashed #5c5e5e; width: 100px; margin-bottom: 0;"/>
                                <p style="margin-top: 5px;">Signature of<br/>Student</p>
                            </div>
                            <div style="float: right; clear: both; margin-right:5px;color: #5c5e5e; font-size: 9px;">
                                <hr style="border: none; border-top: 1px dashed #5c5e5e; width: 100px; margin-bottom: 0;"/>
                                <p style="margin-top: 5px;">Signature of<br/>Issuing Authority</p>
                            </div>
                            <!--  <p style="float: left; margin-left:25px; color:  #5c5e5e;;font-family: Calibri, sans-serif; font-size: 10px; ">Signature Of<br/>Student</p>
                                  <p style="float: right; clear: both; margin-right:5px;color: #5c5e5e;;font-family: Calibri, sans-serif; font-size: 10px; ">Signature Of <br/>Issuing Authority</p>-->
                        </div>
                    </td>
                    
                </table>
                <br/>               
            </body><br/><br/><br/><br/><br/><br/><br/><br/><br/><br/><br/><br/><br/><br/><br/><br/><br/><br/><br/><br/><br/><br/><br/><br/>
            
        </apex:outputPanel>
        <!--show error message if payment is pending -->
        <apex:outputPanel rendered="{!OR(transRegList.Registration_Status__c == 'Payment Pending', transRegList.Registration_Status__c =='Cancelled' )}">
            <p style="text-align: center; font-size:large; color: red;"> Cannot generate the bus pass 
                <apex:outputText rendered="{!transRegList.Registration_Status__c == 'Payment Pending'}">
                    as payment is pending.
                </apex:outputText>
                <apex:outputText rendered="{!transRegList.Registration_Status__c == 'Cancelled'}">
                    as transportation is cancelled.
                </apex:outputText> </p>
        </apex:outputPanel>  
    </html>
</apex:page>