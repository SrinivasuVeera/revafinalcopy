                                                            <td class="slds-is-resizable" scope="col">
                                                                {!open.Sequence__c}
                                                            </td>
                                                            <td class="slds-is-resizable" scope="col">
                                                                {!open.hed__Course__r.Name}
                                                            </td>
                                                            <td class="slds-is-resizable" scope="col">
                                                                {!open.Course_ID__c}
                                                            </td>
                                                            <td class="slds-is-resizable" scope="col">
                                                                {!open.hed__Course__r.HardCore_Sub_Type__c}
                                                            </td>
                                                            <td class="slds-is-resizable" scope="col">
                                                                <aura:if
                                                                    isTrue="{!open.Parent_Course_Offering__c == null}">
                                                                    {!open.Credits__c}
                                                                </aura:if>
                                                            </td>
                                                            <td class="slds-is-resizable" scope="col">
                                                                <aura:if
                                                                    isTrue="{!open.Parent_Course_Offering__c == null}">
                                                                </aura:if>
                                                                <aura:if
                                                                    isTrue="{!open.Parent_Course_Offering__c != null}">
                                                                    <lightning:select
                                                                        name="{!'lstOpenElective__' + index}" label=""
                                                                        value="{!open.Preference__c}"
                                                                        disabled="{!or(v.OpenEle,v.ProfPreference)}"
                                                                        onchange="{!c.changePreference}">
