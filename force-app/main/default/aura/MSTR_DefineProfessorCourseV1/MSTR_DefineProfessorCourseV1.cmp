                                                class="slds-table slds-tablebordered slds-tablecell-buffer slds-tablestriped">
                                                <thead>
                                                    <tr class="slds-text-headinglabel">
                                                        <th class="slds-is-resizable" scope="col">
                                                            Sequence
                                                        </th>
                                                        <th class="slds-is-resizable" scope="col">
                                                            Course
                                                        </th>
                                                        <th class="slds-is-resizable" scope="col">
                                                            Course Id
                                                        </th>
                                                        <th class="slds-is-resizable" scope="col">
                                                            Sub-Type
                                                        </th>
                                                        <th class="slds-is-resizable" scope="col">
                                                            Credits
                                                        </th>
                                                        <th class="slds-is-resizable" scope="col">
                                                            Choose Preference
                                                        </th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <aura:iteration items="{!v.lstOpenElective}" var="open"
                                                        indexVar="index">
