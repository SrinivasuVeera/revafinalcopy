                                                                        <aura:iteration items="{!v.TheoryPreferences}"
                                                                            var="val">
                                                                            <option value="{!val.key}"> {!val.value}
                                                                            </option>
                                                                        </aura:iteration>
                                                                    </lightning:select>
                                                                </aura:if>
                                                            </td>
                                                        </tr>
                                                    </aura:iteration>
                                                </tbody>
                                            </table>
                                        </aura:if>
                                    </lightning:tab> -->
                                        <lightning:tab label="Mandatory Courses">
                                            <aura:if isTrue="{!not(empty(v.lstMandatory))}">
                                                <table
                                                    class="slds-table slds-table--bordered slds-table--cell-buffer slds-table--striped">
                                                    <thead>
                                                        <tr class="slds-text-heading--label">
                                                            <th class="slds-is-resizable" scope="col">
                                                                Sequence
                                                            </th>
                                                            <th class="slds-is-resizable" scope="col">
                                                                Course
                                                            </th>
                                                            <th class="slds-is-resizable" scope="col">
                                                                Course Id
                                                            </th>
                                                            <th class="slds-is-resizable" scope="col">
                                                                Sub-Type
                                                            </th>
                                                            <th class="slds-is-resizable" scope="col">
                                                                Credits
                                                            </th>
                                                            <th class="slds-is-resizable" scope="col">
                                                                Choose Preference
                                                            </th>
                                                            <th class="slds-is-resizable" scope="col">
                                                                No.of Times Course Handled
                                                            </th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <aura:iteration items="{!v.lstMandatory}" var="Mandtory"
                                                            indexVar="index">
                                                            <tr class="slds-hint-parent">
                                                                <td class="slds-is-resizable" scope="col">
                                                                    {!Mandtory.Sequence__c}
                                                                </td>
                                                                <td class="slds-is-resizable" scope="col">
                                                                    {!Mandtory.hed__Course__r.Name}
                                                                </td>
                                                                <td class="slds-is-resizable" scope="col">
                                                                    {!Mandtory.Course_ID__c}
                                                                </td>
                                                                <td class="slds-is-resizable" scope="col">
                                                                    {!Mandtory.hed__Course__r.HardCore_Sub_Type__c}
                                                                </td>
                                                                <td class="slds-is-resizable" scope="col">
                                                                    {!Mandtory.Credits__c}
                                                                </td>
                                                                <td class="slds-is-resizable" scope="col">
                                                                    <lightning:select value="{!Mandtory.Preference__c}"
                                                                        name="{!'lstMandatory__' + index}" label=""
                                                                        disabled="{!or(v.ManCourse,v.ProfPreference)}"
                                                                        onchange="{!c.changePreference}">
                                                                        <option value="">--None--</option>
                                                                        <aura:iteration items="{!v.TheoryPreferences}"
                                                                            var="val">
                                                                            <option value="{!val.key}"> {!val.value}
                                                                            </option>
                                                                        </aura:iteration>
                                                                    </lightning:select>
                                                                </td>
                                                                <td class="slds-is-resizable" scope="col">
                                                                    <lightning:input type="number" 
                                                                                     label="Times Handled" 
                                                                                     variant="label-hidden"
                                                                                     value="{!Mandtory.Number_of_Times_Course_Handled__c}" 
                                                                                     min="0" 
                                                                                     required="{!not(empty(Mandtory.Preference__c))}"
                                                                                     disabled="{!v.ProfPreference}"/>
                                                                </td>
                                                            </tr>
                                                        </aura:iteration>
                                                    </tbody>
                                                </table>
                                            </aura:if>
                                        </lightning:tab>
                                    </lightning:tabset>
                                </div>

                                <aura:set attribute="else">
                                    <div class="no-data-message">
                                        <p>You currently have no courses available for preference selection</p>
                                    </div>
                                </aura:set>

                            </aura:if>
                            <aura:set attribute="else">
                                <div class="no-data-message2">
                                    <p>Please select a <strong>Semester</strong> to view the Preference Collection Form
                                        here.</p>
                                </div>
                            </aura:set>
                        </aura:if>
                    </div>
                </div>
            </div>
        </div>
        <div style="border-radius: 20px ;margin: 25px;">
            <c:getProfessorExistingPreferences oncoursedata="{!c.handleExistingPreferences}" />
        </div>

    </div>
</aura:component>